{
  "name": "pizzacalc-monorepo",
  "private": true,
  "packageManager": "pnpm@10.32.1",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "build": "pnpm --filter pizzacalc build",
    "test": "pnpm --filter pizzacalc test",
    "test:coverage": "pnpm --filter pizzacalc test:coverage",
    "lint": "pnpm --filter pizzacalc lint",
    "check": "pnpm --filter pizzacalc check",
    "checkTs": "pnpm --filter pizzacalc checkTs",
    "deploy": "pnpm --filter deployment cdk deploy"
  }
}
